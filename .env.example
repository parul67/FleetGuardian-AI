# ──────────────────────────────────────────────────────────────────────────────
# FleetGuardian AI – Environment Configuration Template
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and replace ALL placeholder values before running.
#   cp .env.example .env
#
# NEVER commit your .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL Database ────────────────────────────────────────────────────────
# For Docker Compose (local): keep POSTGRES_HOST=postgres (the service name)
# For AWS RDS / external DB:  set POSTGRES_HOST to your RDS endpoint URL
POSTGRES_USER=fleetadmin
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=fleetguardian
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── FastAPI Backend ────────────────────────────────────────────────────────────
API_V1_STR=/api/v1
PROJECT_NAME="FleetGuardian AI"
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_SECRETS_TOKEN_HEX
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:80

# ── Grafana Monitoring ─────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ── Application Settings ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
DEBUG=false

# ── Model Paths ────────────────────────────────────────────────────────────────
PHONE_MODEL_PATH=yolo11n.pt
SEATBELT_MODEL_PATH=yolo11n.pt
FACE_LANDMARKER_PATH=face_landmarker.task
ACCIDENT_MODEL_PATH=models/risk_predictor.pkl

